{
  "version": "0.0.1",
  "npmClient": "yarn",
  "useWorkspaces": false,
  "packages": [
    "algorithm/*",
    "command/*",
    "core/*"
  ],
  "command": {
    "create": {
      "homepage": "https://github.com/what-another-stupid-dimension/wasd",
      "license": "GPL-3.0-or-later"
    },
    "version": {
      "allowBranch": "master",
      "conventionalCommits": true,
      "exact": true,
      "message": "chore(release): %s"
    },
    "run": {
      "npmClient": "yarn"
    }
  },
  "ignoreChanges": [
    "**/__fixtures__/**",
    "**/__tests__/**",
    "**/*.md",
    "**/tsconfig.json",
    "**/jest.config.js"
  ]
}
