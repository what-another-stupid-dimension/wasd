{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "noImplicitAny": true,
    "noLib": false,
    "removeComments": true,
    "sourceMap": true,
    "strict": true,
    "target": "es5",
    "baseUrl": ".",
    "paths": {
      "@wasd/math": ["core/math/src"],
      "@wasd/physics": ["core/physics/src"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/*.test.ts",

    "**/*.spec.ts",
    "**/__tests__/*.ts",
    "**/*.js"
  ]
}
